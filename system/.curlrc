# Default options applied to every curl invocation.
# curl reads this file automatically on startup.
#
# DOCUMENTATION: man curl
#
# PHILOSOPHY:
#   Only options that are universally safe and correct belong here.
#   Options that change output format or behaviour in ways that could
#   break scripts or surprise teammates are commented out.
#
# DISABLING AN OPTION FOR ONE CALL:
#   Prefix the option name with 'no-':
#     curl --no-location https://example.com
#
# ─────────────────────────────────────────────────────────────────
# WHAT IS ACTIVE AND WHY
# ─────────────────────────────────────────────────────────────────
#
# Only two things are active:
#   1. TLS 1.2 minimum — connecting to a server that only supports
#      TLS 1.0 or 1.1 is a security risk. These protocols are broken.
#      This is the one setting that genuinely should be always on.
#
#   2. show-error — without this, using -s (silent) in a script
#      swallows all error messages, making failures invisible.
#      This restores error visibility without affecting normal output.
#
# Everything else is commented. The defaults curl ships with are
# already reasonable. Adding options here affects EVERY curl call,
# including calls made by scripts and other programs.

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────

# Require TLS 1.2 or higher for all connections.
# TLS 1.0 and 1.1 are deprecated (RFC 8996) and have known vulnerabilities.
# curl's default allows older TLS versions — this tightens it.
# To connect to a legacy server that only supports TLS 1.0 (e.g. old appliance),
# override with: curl --tlsv1.0 https://old-server.example.com
#tlsv1.2

# Show error messages even when silent mode (-s) is active.
# Without this, 'curl -s https://example.com' produces no output on failure,
# making it hard to debug why a script is not working.
show-error

# ─────────────────────────────────────────────────────────────────
# CONNECTION (commented — curl defaults are fine)
# ─────────────────────────────────────────────────────────────────

# Follow HTTP redirects (301, 302, 307, etc.) automatically.
# Without this, curl returns the redirect response body, not the final content.
# Commented because: scripts sometimes WANT the redirect response.
#   If you want this always: uncomment it.
#   If you want it for one call: curl -L https://example.com
# location

# Maximum number of redirects to follow before giving up.
# Prevents infinite redirect loops.
# Only meaningful if 'location' is enabled.
# max-redirs = 10

# Fail if the connection cannot be established within N seconds.
# curl's default is never (waits forever for TCP connection).
# 10 seconds is reasonable for interactive use.
# Commented because: batch jobs, scripts, or slow networks may need longer.
#   If you want a global timeout: uncomment and adjust.
# connect-timeout = 10

# Maximum time for the entire transfer (connection + download).
# Prevents curl from hanging indefinitely on extremely slow servers.
# 60 seconds may be too short for large downloads.
# Commented because: the right value depends on what you are downloading.
#   For large files, set per-call: curl --max-time 300 https://example.com/big.iso
# max-time = 60

# Number of retry attempts on transient failure.
# curl retries only on network-level errors, not HTTP error codes.
# Commented because: retrying by default can mask problems or cause
#   duplicate side effects (e.g. retrying a POST request).
# retry = 3

# Wait N seconds between retry attempts.
# Only meaningful if 'retry' is set.
# retry-delay = 2

# ─────────────────────────────────────────────────────────────────
# OUTPUT (commented — only useful for interactive use)
# ─────────────────────────────────────────────────────────────────

# Show a progress bar during downloads.
# --progress-bar shows a simple bar instead of the default statistics table.
# Commented because: progress output goes to stderr and can interfere
#   with scripts that parse curl's output.
#   For interactive use: curl --progress-bar -O https://example.com/file
# progress-bar

# Write the HTTP response headers to a file.
# Useful for debugging but not appropriate as a global default.
# dump-header = /tmp/curl_headers.txt

# ─────────────────────────────────────────────────────────────────
# USER AGENT (commented)
# ─────────────────────────────────────────────────────────────────

# Set a custom User-Agent header.
# Some servers reject curl's default "curl/x.x.x" user agent.
# Commented because: changing the user agent misrepresents the client,
#   which can cause unexpected behaviour and makes debugging harder.
#   If a specific server requires it, set it per call:
#     curl -A "Mozilla/5.0" https://example.com
# user-agent = "Mozilla/5.0 (compatible; curl)"

# ─────────────────────────────────────────────────────────────────
# CA CERTIFICATES (commented)
# ─────────────────────────────────────────────────────────────────

# Path to the CA certificate bundle for TLS verification.
# curl uses the system bundle by default (compiled in at build time).
# Only needed if your system bundle is in a non-standard location
# or if you need to add custom internal CA certificates.
#   Debian/Ubuntu default: /etc/ssl/certs/ca-certificates.crt
#   RHEL/Fedora default:   /etc/pki/tls/certs/ca-bundle.crt
# cacert = /etc/ssl/certs/ca-certificates.crt

# ─────────────────────────────────────────────────────────────────
# PROXY (commented)
# ─────────────────────────────────────────────────────────────────

# Route all requests through an HTTP proxy.
# Commented because: this is machine/network-specific configuration
#   that should not be committed to dotfiles.
#   Set in ~/.curlrc.local or as an environment variable instead:
#     export https_proxy=http://proxy.company.com:8080
# proxy = http://proxy.example.com:8080

# Bypass the proxy for these hosts (comma-separated).
# noproxy = localhost,127.0.0.1,.internal.company.com