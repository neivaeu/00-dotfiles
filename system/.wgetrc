# Default options applied to every wget invocation.
# wget reads this file automatically on startup.
#
# DOCUMENTATION: man wget
# Full reference: https://www.gnu.org/software/wget/manual/wget.html
#
# PHILOSOPHY:
#   Same as .curlrc — only universally safe defaults are active.
#   wget is used less frequently than curl in interactive sessions,
#   but more frequently in scripts and automated downloads.
#   Keep this minimal.
#
# NOTE ON curl vs wget:
#   curl and wget overlap significantly but have different strengths:
#     curl:  better for API calls, sending data, custom headers, scripting
#     wget:  better for recursive download, mirroring sites, resuming downloads
#   Both read their own config files (~/.curlrc and ~/.wgetrc respectively).

# ─────────────────────────────────────────────────────────────────
# WHAT IS ACTIVE AND WHY
# ─────────────────────────────────────────────────────────────────
#
# Active settings:
#   check-certificate — same reasoning as tlsv1.2 in curlrc.
#                       Never disable TLS verification. Ever.
#   tries             — wget retrying 3 times is almost always correct
#                       for downloads. Unlike curl, wget is typically
#                       used for files, not API calls with side effects.

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────

# Verify the server's TLS certificate against the CA bundle.
# Setting this to 'off' disables certificate validation entirely —
# never do this, it makes TLS useless against man-in-the-middle attacks.
# wget's default is 'on' — this line makes the intent explicit.
check-certificate = on

# ─────────────────────────────────────────────────────────────────
# CONNECTION
# ─────────────────────────────────────────────────────────────────

# Number of retry attempts when a connection fails.
# wget is typically used for file downloads where transient failures are
# common (network blips, server load). 3 retries is a safe default.
# Unlike curl API calls, retrying a download does not cause side effects.
tries = 3

# Wait between retries (seconds).
# Giving a server time to recover before retrying is good practice.
# Commented because: the right wait time is context-dependent.
# wait = 2

# ─────────────────────────────────────────────────────────────────
# CONNECTION TIMEOUTS (commented)
# ─────────────────────────────────────────────────────────────────

# DNS lookup timeout in seconds.
# wget's default is never (can hang indefinitely on broken DNS).
# Uncomment for faster failure on DNS problems.
# dns-timeout = 10

# TCP connection timeout in seconds.
# wget's default is never.
# Uncomment if you want wget to give up on unresponsive servers quickly.
# connect-timeout = 10

# Read timeout — time to wait for data after connection is established.
# If the server stops sending data, wget waits this long before giving up.
# wget's default is never.
# read-timeout = 30

# ─────────────────────────────────────────────────────────────────
# BEHAVIOUR (commented)
# ─────────────────────────────────────────────────────────────────

# Use the filename suggested by the server's Content-Disposition header.
# Example: a URL like /download?id=123 with header
#          Content-Disposition: attachment; filename="report.pdf"
#          would save as report.pdf instead of 123.
# Safe to uncomment for interactive use.
# content-disposition = on

# Show a progress bar instead of the default dot-based progress indicator.
# Options: dot, bar
# bar is more informative and familiar.
# Commented because: progress output can interfere with scripts.
# progress = bar

# Append wget's output log to a file instead of printing to stderr.
# Useful for batch jobs. Not appropriate as a global default.
# output-file = /tmp/wget.log

# ─────────────────────────────────────────────────────────────────
# RECURSIVE DOWNLOAD (commented — powerful, use with care)
# ─────────────────────────────────────────────────────────────────

# Maximum recursion depth when mirroring sites.
# wget -r (recursive) follows links indefinitely by default.
# Setting a limit prevents accidentally downloading the entire internet.
# Only meaningful when running wget with -r or -m (mirror).
# recdepth = 3

# Domains to restrict recursive downloads to (comma-separated).
# Prevents wget from following links to external sites.
# domains = example.com

# ─────────────────────────────────────────────────────────────────
# PROXY (commented — machine-specific, do not commit)
# ─────────────────────────────────────────────────────────────────

# HTTP proxy.
# Set as environment variable instead to avoid committing to dotfiles:
#   export http_proxy=http://proxy.company.com:8080
# https_proxy = http://proxy.example.com:8080

# Bypass proxy for these addresses.
# no_proxy = localhost,127.0.0.1,.internal.company.com

# ─────────────────────────────────────────────────────────────────
# CA CERTIFICATES (commented)
# ─────────────────────────────────────────────────────────────────

# Path to the CA certificate bundle.
# wget uses the system bundle by default.
# Only needed if you have custom internal CA certificates.
# ca-certificate = /etc/ssl/certs/ca-certificates.crt