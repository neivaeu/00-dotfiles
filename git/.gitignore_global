# Patterns ignored in ALL repositories on this machine.
# Symlinked to ~/.gitignore_global by bootstrap/install.sh
# Referenced in ~/.gitconfig: core.excludesfile = ~/.gitignore_global
#
# PURPOSE:
#   This file ignores things that are specific to your machine or tools,
#   not to any particular project.
#
# RULE:
#   If a pattern belongs to a specific project, put it in that project's
#   own .gitignore — not here.
#   If it belongs to your editor, OS, or development environment
#   on every machine — put it here.
#
# DEBUGGING:
#   Why is a file being ignored?
#     git check-ignore -v filename
#   Show all ignored files in the current repository:
#     git status --ignored

# ─────────────────────────────────────────────────────────────────
# OPERATING SYSTEM FILES
# ─────────────────────────────────────────────────────────────────

# macOS — Finder metadata files, created automatically
.DS_Store
.DS_Store?
# macOS extended attribute files (created when copying to non-HFS+ volumes)
._*
# macOS Spotlight search index
.Spotlight-V100
# macOS Trash metadata
.Trashes
# macOS double-file packaging artefacts
.AppleDouble
.LSOverride

# Linux — desktop environment metadata
# KDE Dolphin folder view configuration
.directory
# Backup files created by editors (vim, nano, gedit use filename~)
*~
# FUSE virtual filesystem temporary files
.fuse_hidden*
# NFS temporary files
.nfs*

# Windows — file manager and system metadata
# Windows thumbnail cache (created in every directory the user browses)
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
# Windows folder configuration file
desktop.ini
# Windows Recycle Bin metadata
$RECYCLE.BIN/
# Windows shortcut files
*.lnk

# ─────────────────────────────────────────────────────────────────
# EDITOR FILES
# ─────────────────────────────────────────────────────────────────

# Vim
# Swap files — created while a file is open in vim
*.swp
*.swo
*.swn
# Swap file pattern variants
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
# Undo history file (vim -u NORC or :set undofile)
*.un~
# Session files
Session.vim
# Tag files (generated by ctags — can also go in project .gitignore)
tags
TAGS
.tags
.TAGS
# Netrw history (vim file browser)
.netrwhist

# VS Code
# Editor settings directory — often contains machine-specific paths
# NOTE: some teams commit .vscode/settings.json for shared editor config.
#       If your team does this, add '!.vscode/settings.json' to project .gitignore.
.vscode/
*.code-workspace

# JetBrains IDEs (CLion, IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Emacs
# Auto-save files (created when editing)
\#*\#
# Lock files (created when a file is open)
.\#*
# Desktop session file
.emacs.desktop
.emacs.desktop.lock
# Compiled elisp
*.elc
# Auto-save list
auto-save-list
# Tramp connection history
tramp

# Sublime Text
*.sublime-workspace

# Nano
# Backup files
*.save

# ─────────────────────────────────────────────────────────────────
# C COMPILED OUTPUT
# ─────────────────────────────────────────────────────────────────
# These are build artefacts — never should be committed.
# The source files produce them; they do not need version control.

# Object files — compiled from individual .c files
*.o
*.obj

# Static libraries — archives of object files (e.g. libft.a)
*.a
*.lib

# Shared libraries — dynamically linked libraries
*.so
*.so.*
*.dylib
*.dll

# Compiled executables (Windows)
*.exe

# Default gcc output when no -o flag is given
a.out

# Preprocessed output (gcc -E)
*.i
*.ii

# Assembly output (gcc -S)
*.s

# Dependency files (generated by -MMD -MP flags)
# Included by Makefiles to track header dependencies
*.d

# Debug symbol files
*.dSYM/
*.su
*.idb
*.pdb

# Coverage instrumentation output (gcov/lcov)
*.gcno
*.gcda
*.gcov

# Profiling output
gmon.out
perf.data
perf.data.old

# Valgrind output files
vgcore.*

# Sanitiser log output
asan.log*
ubsan.log*
lsan.log*
tsan.log*

# ─────────────────────────────────────────────────────────────────
# BUILD DIRECTORIES
# ─────────────────────────────────────────────────────────────────
# Common names for directories that contain build output.
# If a project uses one of these names for source files,
# add a negation in the project's .gitignore: !build/src/

obj/
build/
dist/
out/
bin/
target/

# ─────────────────────────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────────────────────────

# Compiled bytecode (generated automatically when importing modules)
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments — machine-specific, never commit these
.venv/
venv/
env/
ENV/
.Python

# Package distribution artefacts
*.egg-info/
dist/
build/

# Test and coverage output
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# pyenv version file — machine-specific Python version selection
.python-version

# ─────────────────────────────────────────────────────────────────
# NODE / JAVASCRIPT
# ─────────────────────────────────────────────────────────────────

# Dependencies directory — always regenerated from package.json
node_modules/

# Package manager log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Node REPL history
.node_repl_history

# ─────────────────────────────────────────────────────────────────
# SECRETS AND SENSITIVE FILES
# ─────────────────────────────────────────────────────────────────
# These must NEVER be committed. Committing secrets to git is a
# serious security incident — they remain in history even after deletion.

# Environment files — often contain API keys, database passwords, etc.
.env
.env.local
.env.*.local
.envrc

# TLS/SSL certificates and private keys
*.pem
*.key
*.p12
*.pfx

# SSH private keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub

# AWS credentials
.aws/credentials

# ─────────────────────────────────────────────────────────────────
# LOGS AND TEMPORARY FILES
# ─────────────────────────────────────────────────────────────────

*.log
*.tmp
*.temp
*.bak
*.orig
*.rej

# Core dump files (generated when a process crashes)
core
core.*

# GDB command history and output files
.gdb_history

# ─────────────────────────────────────────────────────────────────
# ARCHIVES
# ─────────────────────────────────────────────────────────────────
# Compressed archives are usually build artefacts or downloaded dependencies.
# They are large, binary, and should not be version controlled.
# If a project legitimately tracks an archive, add '!filename.tar.gz'
# to the project's .gitignore.

*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tbz2
*.tar.xz
*.txz
*.zip
*.7z
*.rar
*.gz
*.bz2
*.xz